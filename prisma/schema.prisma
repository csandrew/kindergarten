generator client {
  provider = "prisma-client-js"
}

// FIXED: Changed from sqlite to postgresql
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String
  childName   String?
  content     String
  rating      Int      @default(5)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Enrollment {
  id                Int      @id @default(autoincrement())
  childName         String
  childAge          Int
  parentName        String
  parentEmail       String
  parentPhone       String
  program           String
  preferredStartDate DateTime
  message           String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
}

model PrincipalMessage {
  id        Int      @id @default(autoincrement())
  content   String
  name      String
  title     String
  imageUrl  String
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id         Int      @id @default(autoincrement())
  section    String   @unique
  content    String
  updatedAt  DateTime @updatedAt
}